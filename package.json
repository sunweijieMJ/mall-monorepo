{
  "name": "mall-monorepo",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo dev --concurrency=20",
    "build": "turbo build",
    "clean": "turbo clean",
    "lint": "turbo lint",
    "test": "turbo test",
    "type-check": "turbo run type-check",
    "commit": "cross-env NODE_OPTIONS=\"--experimental-transform-types --disable-warning=ExperimentalWarning\" czg",
    "cspell": "cspell",
    "format": "prettier . --write",
    "lint:md": "markdownlint-cli2 '**/*.{md}'",
    "lint:cssVars": "tsx scripts/cssVars/checkCssVars.ts",
    "postinstall": "npx husky"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix"
    ],
    "*.{css,scss,less,vue}": [
      "stylelint --fix"
    ],
    "*.md": [
      "pnpm run lint:md"
    ],
    "*": [
      "pretty-quick --staged"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@commitlint/format": "^20.4.0",
    "@commitlint/types": "^20.4.0",
    "@kit/eslint-config": "workspace:*",
    "@kit/stylelint-config": "workspace:*",
    "@kit/typescript-config": "workspace:*",
    "@types/node": "^25.3.2",
    "chalk": "^5.6.2",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cspell": "^9.7.0",
    "cz-git": "^1.12.0",
    "czg": "^1.12.0",
    "eslint": "^10.0.0",
    "glob": "^11.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "rimraf": "^6.1.3",
    "stylelint": "^17.1.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.11",
    "typescript": "5.9.3",
    "@vitejs/plugin-vue": "^5.2.3",
    "vitest": "^3.2.0"
  }
}
