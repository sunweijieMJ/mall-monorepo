{
  "name": "mall-server",
  "version": "1.0.0",
  "description": "Mall 电商后端 API 服务",
  "scripts": {
    "typeorm": "env-cmd ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "pnpm typeorm -- --dataSource=src/infrastructure/database/data-source.ts migration:generate",
    "postmigration:generate": "pnpm lint:fix",
    "migration:create": "pnpm typeorm -- migration:create",
    "migration:run": "pnpm typeorm -- --dataSource=src/infrastructure/database/data-source.ts migration:run",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js --dataSource=dist/infrastructure/database/data-source.js migration:run",
    "migration:revert": "pnpm typeorm -- --dataSource=src/infrastructure/database/data-source.ts migration:revert",
    "seed:run": "ts-node -r tsconfig-paths/register ./src/infrastructure/database/seeds/run-seed.ts",
    "clean": "rimraf dist",
    "build": "nest build",
    "dev": "nest start -b swc -w",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "docker:infra": "docker compose up -d",
    "docker:infra:down": "docker compose down",
    "docker:build": "docker build -f Dockerfile -t mall-server ../../",
    "docker:prod": "docker compose -f deploy/docker-compose.prod.yaml up -d --remove-orphans",
    "docker:prod:down": "docker compose -f deploy/docker-compose.prod.yaml down",
    "docker:logs": "docker compose -f deploy/docker-compose.prod.yaml logs -f api",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@alicloud/dysmsapi20170525": "^4.5.0",
    "@alicloud/openapi-client": "^0.4.15",
    "@aws-sdk/client-s3": "3.1002.0",
    "@aws-sdk/s3-request-presigner": "3.1002.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "11.1.15",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.15",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.15",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "11.0.0",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "bcryptjs": "3.0.3",
    "bullmq": "^5.70.2",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "dotenv": "17.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "ms": "2.1.3",
    "multer": "2.1.1",
    "multer-s3": "3.0.1",
    "nestjs-i18n": "10.6.0",
    "nestjs-pino": "^4.6.0",
    "nodemailer": "8.0.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "8.20.0",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "redis": "^5.10.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "swagger-ui-express": "5.0.1",
    "typeorm": "0.3.28"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:*",
    "@types/multer-s3": "3.0.3",
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.15",
    "@swc/cli": "0.8.0",
    "@swc/core": "1.15.18",
    "@types/bcryptjs": "3.0.0",
    "@types/express": "5.0.6",
    "@types/ms": "2.1.0",
    "@types/multer": "2.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "7.2.0",
    "@types/node": "*",
    "env-cmd": "11.0.0",
    "eslint": "*",
    "pino-pretty": "^13.1.3",
    "rimraf": "*",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "*",
    "vitest": "*"
  }
}
