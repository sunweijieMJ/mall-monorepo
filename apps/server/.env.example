# =============================================================================
# Mall Server 环境变量配置
# =============================================================================
# 使用说明:
#   1. 复制本文件为 .env: cp .env.example .env
#   2. 按需填写各配置项（⚠️ 标注的项在生产环境必须修改）
#   3. .env 文件不会被提交到 git（已在 .gitignore 中排除）
# =============================================================================


# =============================================================================
# 应用基础配置
# =============================================================================

# 运行环境: development | production | test
NODE_ENV=development

# 应用监听端口
APP_PORT=3001

# 应用名称（用于 Swagger 文档标题、日志标识等）
APP_NAME="Mall API"

# 全局 API 前缀（最终路径: /api/v1/...）
API_PREFIX=api

# 默认语言（用于 i18n 回退）
APP_FALLBACK_LANGUAGE=zh

# 客户端语言请求头名称
APP_HEADER_LANGUAGE=x-custom-lang

# 前端域名（用于 CORS 跨域配置）
FRONTEND_DOMAIN=http://localhost:5173

# 后端域名（用于生成回调 URL、邮件链接等）
BACKEND_DOMAIN=http://localhost:3001


# =============================================================================
# 日志配置（nestjs-pino）
# =============================================================================

# 日志级别: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=debug

# 是否启用美化输出（开发环境建议 true，生产建议 false 输出 JSON）
LOG_PRETTY_PRINT=true


# =============================================================================
# 数据库配置（PostgreSQL）
# =============================================================================

DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=root
# ⚠️ 生产环境必须修改为强密码
DATABASE_PASSWORD=secret
DATABASE_NAME=mall

# 是否自动同步实体到数据库（⚠️ 生产环境必须为 false，使用 migration）
DATABASE_SYNCHRONIZE=false

# 最大连接数
DATABASE_MAX_CONNECTIONS=100

# SSL 配置（生产环境根据数据库服务商要求开启）
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
# PEM 格式证书（SSL 开启时填写）
DATABASE_CA=
DATABASE_KEY=
DATABASE_CERT=

# 完整连接 URL（填写后会覆盖上方拆分配置，适用于云数据库直连场景）
# 格式: postgres://username:password@host:port/dbname
DATABASE_URL=


# =============================================================================
# 文件存储配置
# =============================================================================

# 存储驱动: local | s3 | s3-presigned（阿里云 OSS 兼容 S3 协议）
FILE_DRIVER=local

# AWS S3 / 阿里云 OSS（FILE_DRIVER=s3 或 s3-presigned 时填写）
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
AWS_S3_REGION=
AWS_DEFAULT_S3_BUCKET=
# 自定义 Endpoint（阿里云 OSS 示例: https://oss-cn-hangzhou.aliyuncs.com）
AWS_S3_ENDPOINT=


# =============================================================================
# 邮件配置（nodemailer）
# =============================================================================

# SMTP 服务器地址（本地开发可使用 maildev: localhost）
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
# ⚠️ 生产环境必须填写真实密码
MAIL_PASSWORD=

# TLS 配置（生产环境根据 SMTP 服务商要求调整）
MAIL_IGNORE_TLS=true
MAIL_SECURE=false
MAIL_REQUIRE_TLS=false

# 发件人信息
MAIL_DEFAULT_EMAIL=noreply@mall.com
MAIL_DEFAULT_NAME=Mall


# =============================================================================
# 认证配置（JWT）
# =============================================================================

# 访问令牌（Access Token）
# ⚠️ 生产环境必须替换为随机强密钥（建议 64 位以上随机字符串）
AUTH_JWT_SECRET=change_this_to_a_random_secret_in_production
# 过期时间（支持 ms 格式: 15m | 1h | 1d）
AUTH_JWT_TOKEN_EXPIRES_IN=15m

# 刷新令牌（Refresh Token）
# ⚠️ 生产环境必须替换，且与 JWT_SECRET 不同
AUTH_REFRESH_SECRET=change_this_to_another_random_secret_in_production
AUTH_REFRESH_TOKEN_EXPIRES_IN=3650d

# 忘记密码令牌
AUTH_FORGOT_SECRET=change_this_forgot_secret_in_production
AUTH_FORGOT_TOKEN_EXPIRES_IN=30m

# 邮箱验证令牌
AUTH_CONFIRM_EMAIL_SECRET=change_this_confirm_secret_in_production
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d


# =============================================================================
# Redis 配置（缓存 + 消息队列 BullMQ）
# =============================================================================

# 是否启用 Redis（关闭后缓存降级为内存，BullMQ 队列不可用）
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
# ⚠️ 生产环境必须设置密码
REDIS_PASSWORD=
# Redis 数据库编号（0-15）
REDIS_DB=0


# =============================================================================
# 限流配置（@nestjs/throttler）
# =============================================================================

# 是否启用限流（CI/测试环境建议关闭）
THROTTLER_ENABLED=false
# 时间窗口（毫秒，默认 60000 即 60 秒）
THROTTLER_TTL=60000
# 时间窗口内最大请求数
THROTTLER_LIMIT=100


# =============================================================================
# 监控指标配置（Prometheus）
# =============================================================================

# 是否暴露 /metrics 端点
METRICS_ENABLED=true
# metrics 端点路径
METRICS_PATH=metrics


# =============================================================================
# 阿里云短信配置（SMS）
# =============================================================================

# 阿里云 RAM 访问密钥
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=

# 短信签名（需在阿里云控制台申请）
SMS_SIGN_NAME=
# 短信模板 CODE（需在阿里云控制台创建）
SMS_TEMPLATE_CODE=


# =============================================================================
# 阿里云 OSS 配置（图片/文件直传）
# =============================================================================

# OSS 服务端点（地域示例: oss-cn-hangzhou.aliyuncs.com）
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET_NAME=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
# 文件存储目录前缀（末尾需加 /）
ALIYUN_OSS_DIR=mall/


# =============================================================================
# 支付宝配置
# =============================================================================

# 支付宝应用 ID
ALIPAY_APP_ID=
# 应用私钥（RSA2，PKCS8 格式，⚠️ 生产环境妥善保管）
ALIPAY_PRIVATE_KEY=
# 支付宝公钥（用于验签）
ALIPAY_PUBLIC_KEY=
# 网关地址（沙箱: https://openapi.alipaydev.com/gateway.do | 正式: https://openapi.alipay.com/gateway.do）
ALIPAY_GATEWAY=https://openapi.alipaydev.com/gateway.do
# 异步通知回调地址（需外网可访问）
ALIPAY_NOTIFY_URL=http://localhost:3001/api/v1/portal/payment/alipay/notify
# 支付成功后前端跳转地址
ALIPAY_RETURN_URL=http://localhost:5173/pay/success
