{
  "name": "mall-app-web",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:h5": "uni",
    "dev:mp-weixin": "uni -p mp-weixin",
    "dev:app": "uni -p app",
    "build:h5": "uni build",
    "build:mp-weixin": "uni build -p mp-weixin",
    "build:app": "uni build -p app",
    "mp:upload:weixin": "pnpm build:mp-weixin && pnpm tsx scripts/mp-upload.ts weixin upload",
    "mp:preview:weixin": "pnpm build:mp-weixin && pnpm tsx scripts/mp-upload.ts weixin preview",
    "clean": "rimraf dist unpackage",
    "format": "prettier . --write",
    "type-check": "vue-tsc --noEmit",
    "lint": "pnpm lint:script && pnpm lint:style",
    "lint:script": "eslint . --fix",
    "lint:style": "stylelint '**/*.{css,scss,vue}' --fix",
    "test": "vitest --run"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-5000120260205002",
    "@dcloudio/uni-app-plus": "3.0.0-alpha-5000120260205002",
    "@dcloudio/uni-components": "3.0.0-alpha-5000120260205002",
    "@dcloudio/uni-h5": "3.0.0-alpha-5000120260205002",
    "@dcloudio/uni-mp-weixin": "3.0.0-alpha-5000120260205002",
    "@dcloudio/uni-quickapp-webview": "3.0.0-alpha-5000120260205002",
    "core-js": "^3.48.0",
    "lodash-es": "^4.17.23",
    "luch-request": "^3.1.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.29",
    "@dcloudio/uni-automator": "3.0.0-alpha-5000120260205002",
    "@dcloudio/uni-cli-shared": "3.0.0-alpha-5000120260205002",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5000120260205002",
    "@kit/eslint-config": "workspace:*",
    "@kit/stylelint-config": "workspace:*",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "*",
    "@uni-helper/uni-app-types": "1.0.0-alpha.7",
    "@uni-helper/uni-ui-types": "1.0.0-alpha.7",
    "@uni-helper/vite-plugin-uni-layouts": "^0.1.11",
    "@uni-helper/vite-plugin-uni-manifest": "^0.2.12",
    "@uni-helper/vite-plugin-uni-pages": "^0.3.23",
    "@vitejs/plugin-legacy": "^7.2.1",
    "autoprefixer": "^10.4.27",
    "commitizen": "*",
    "cross-env": "*",
    "cz-git": "*",
    "czg": "*",
    "eslint": "*",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "*",
    "pretty-quick": "*",
    "rimraf": "*",
    "sass": "^1.97.3",
    "stylelint": "*",
    "tsx": "*",
    "typescript": "*",
    "vite": "^7.3.1",
    "vitest": "*",
    "miniprogram-ci": "^2.1.26",
    "vue-tsc": "^3.2.5"
  },
  "uni-app": {
    "scripts": {}
  }
}
